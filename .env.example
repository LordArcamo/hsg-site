# Resend (https://resend.com) — used by src/pages/api/lead.ts and src/pages/api/newsletter.ts
# 1. Sign up free, verify a sending domain (or use onboarding@resend.dev for testing — it can
#    only deliver to the email address on your own Resend account).
# 2. Create an API key: https://resend.com/api-keys
# 3. Copy this file to .env and fill in real values below.
# 4. In production (Vercel), set the same three variables under Project Settings > Environment Variables.

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL="Schlager Solutions Group <notifications@schlagersolutionsgroup.com>"
RESEND_TO_EMAIL=hello@schlagersolutionsgroup.com
