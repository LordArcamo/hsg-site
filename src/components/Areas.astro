---
const locations = [
  'Bergen County', 'Passaic County', 'Hudson County', 'Essex County', 'Union County', 'Morris County',
  'Clifton', 'Paramus', 'Hackensack', 'Newark', 'Paterson',
];
---

<section class="section" id="areas" style="background: var(--soft)">
  <div class="wrap serve-layout">
    <div class="serve-card map-card reveal">
      <iframe
        title="Map of Northern New Jersey — Schlager Solutions Group service area"
        src="https://www.openstreetmap.org/export/embed.html?bbox=-74.9%2C40.45%2C-73.9%2C41.1&layer=mapnik&marker=40.7357%2C-74.1724"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
    <div class="serve-card reveal" data-d="1">
      <div class="kicker">Areas We Serve</div>
      <h2 style="font-size: clamp(1.8rem,3.2vw,2.8rem)">Proudly serving businesses across Northern New Jersey.</h2>
      <p class="large-copy">Schlager Solutions Group partners with companies throughout Bergen, Passaic, Essex, Hudson, Morris, Union, and surrounding communities.</p>
      <div class="location-links">
        {locations.map((location) => <a href="#">{location}</a>)}
      </div>
    </div>
  </div>
</section>
