---
import Timeline from './react/Timeline.tsx';
import ArrowIcon from './ArrowIcon.astro';
---

<section class="section">
  <div class="wrap connected">
    <div class="section-head reveal" style="margin-bottom:0">
      <div class="kicker">Connected Challenges</div>
      <h2>Growth rarely fails in one isolated place.</h2>
      <p class="large-copy">
        A hiring decision affects leadership. Leadership shapes culture. Culture influences
        performance. Performance drives growth. Growth creates new challenges. Schlager Solutions Group
        connects those pieces before they become separate problems.
      </p>
      <a class="button button-secondary" href="#contact" style="margin-top:20px">See Where the Gaps Are <ArrowIcon size={15} /></a>
    </div>
    <div class="reveal" data-d="1">
      <Timeline client:visible />
    </div>
  </div>
</section>
