---
import LeadForm from './react/LeadForm.tsx';

const points = [
  'One advisor, not a five-firm relay',
  'Reply within one business day',
  'No obligation — just a conversation',
];
---

<section class="section" id="contact" style="background: var(--soft)">
  <div class="wrap contact-layout">
    <div class="section-head reveal" style="margin-bottom:0">
      <div class="kicker">Get In Touch</div>
      <h2>Tell us where you're stuck.</h2>
      <p class="large-copy">
        Share a few details about your business or your career, and Michael will follow up personally —
        no intake team, no runaround.
      </p>
      <ul class="contact-points">
        {points.map((point) => (
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M4 13l5 5L20 6"></path></svg>{point}</li>
        ))}
      </ul>
      <a class="phone contact-phone" href="tel:13476657733">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        Prefer to talk? 347-665-7733
      </a>
    </div>
    <div class="panel contact-card reveal" data-d="1">
      <LeadForm client:visible />
    </div>
  </div>
</section>
