      <div class="cta-row" style="justify-content: center">
        <a class="button button-primary" href="#contact">Schedule Your Strategy Call <ArrowIcon /></a>
        <a class="phone" href="tel:13476657733">347-665-7733</a>
        <a class="button button-secondary" href="#">Book Online</a>
      </div>
    </div>
  </div>
</section>
