---
import ArrowIcon from './ArrowIcon.astro';
import CountUp from './react/CountUp.tsx';
import RotatingBadge from './react/RotatingBadge.tsx';

const services = ['Business Strategy', 'Executive Recruiting', 'Leadership', 'HR', 'Executive Careers'];

const stats = [
  { color: 'var(--green)', label: 'Years advising', suffix: '+', target: 25, rot: '-3deg' },
  { color: 'var(--purple)', label: 'Business focus', value: 'NJ', rot: '2deg' },
  { color: 'var(--gold)', label: 'Growth paths', target: 5, rot: '-2deg' },
];
---

<section class="hero">
  <div class="wrap hero-layout">
    <div class="hero-content">
      <div class="eyebrow reveal">25+ years serving New Jersey businesses</div>
      <h1 class="reveal" data-d="1">
        {['The', 'Right', 'Decisions'].map((word, i) => (
          <span class="hw"><span style={`--i:${i}`}>{word}</span></span>
        ))}
        <span class="h1-accent">
          {['Change', 'Everything.'].map((word, i) => (
            <span class="hw"><span style={`--i:${i + 3}`}>{word}</span></span>
          ))}
        </span>
      </h1>
      <p class="hero-lede reveal" data-d="2">
        Trusted business advisory for growing companies across New Jersey — connecting strategy,
        executive recruiting, leadership development, HR, and executive career guidance under one relationship.
      </p>
      <ul class="service-line reveal" data-d="2">
        {services.map((service) => <li>{service}</li>)}
      </ul>
      <div class="cta-row reveal" data-d="3">
        <a class="button button-primary" href="#contact">Book Strategy Call <ArrowIcon /></a>
        <a class="button button-secondary" href="#solutions">Explore Solutions</a>
      </div>
    </div>
    <figure class="hero-visual reveal" data-d="2" id="heroVisual">
      <div class="hero-visual-frame">
        <img
          src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1100&q=80"
          alt="Michael Schlager advising a group of business owners and executives"
          loading="eager"
          onerror="this.closest('.hero-visual').classList.add('img-failed')"
        />
      </div>
      <RotatingBadge client:load />
      <div class="hs-badges">
        {stats.map((stat, i) => (
          <div class="hs-badge" style={`--stat-c: ${stat.color}; --rot: ${stat.rot}; --i: ${i}`}>
            <i></i>
            <strong>{stat.target ? <CountUp client:visible target={stat.target} suffix={stat.suffix} /> : stat.value}</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </div>
    </figure>
  </div>
</section>
