---
import ArrowIcon from './ArrowIcon.astro';

const categories = ['Business Strategy', 'Leadership', 'Executive Recruiting', 'HR', 'Career', 'Podcast', 'Videos', 'Newsletter'];
---

<section class="section" id="insights">
  <div class="wrap insight-layout">
    <article class="insight-card featured reveal">
      <div class="kicker">Insights</div>
      <h2 style="font-size: clamp(1.9rem,3.4vw,3rem)">Practical thinking for growing New Jersey businesses.</h2>
      <p class="large-copy" style="margin-bottom:24px">Business strategy, leadership, executive recruiting, HR, and career guidance written for owners, executives, and HR leaders who want to make better decisions.</p>
      <a class="button button-primary" href="#" style="align-self:flex-start">Visit the Insights Center <ArrowIcon /></a>
    </article>
    <div class="category-list reveal" data-d="1" aria-label="Insight categories">
      {categories.map((category) => <a href="#">{category}</a>)}
    </div>
  </div>
</section>
