---
import NewsletterForm from './react/NewsletterForm.tsx';
---

<section class="section" id="newsletter" style="padding-top:0">
  <div class="wrap">
    <div class="panel newsletter reveal">
      <div>
        <div class="kicker">The Advisory Brief</div>
        <h2>Insights worth your inbox.</h2>
        <p>Practical thinking on strategy, leadership, hiring, and growth — written for New Jersey business owners and executives. One useful email a month. No noise.</p>
      </div>
      <div>
        <NewsletterForm client:visible />
        <p class="nl-note">Join business leaders across Bergen, Passaic, Essex, Hudson, Morris &amp; Union. Unsubscribe anytime.</p>
      </div>
    </div>
  </div>
</section>
