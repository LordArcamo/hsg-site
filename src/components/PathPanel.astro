---
import ArrowIcon from './ArrowIcon.astro';
---

<section class="path-panel wrap" id="solutions">
  <div class="panel reveal">
    <h2 class="section-label">What Brings You Here Today?</h2>

    <div class="audience-row reveal"><span class="aud-label">For Companies &amp; Owners</span><span class="aud-line"></span></div>
    <div class="path-grid-4">
      <a class="path-card reveal" href="#contact" style="--card-color: var(--green)">
        <div>
          <div class="path-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 7-7"></path><path d="M17 8h4v4"></path></svg></div>
          <h3>Grow My Business</h3>
          <p>Practical guidance for revenue, operations, succession, and next-stage growth.</p>
        </div>
        <span class="path-go">Business Growth <ArrowIcon size={15} /></span>
      </a>
      <a class="path-card reveal" data-d="1" href="#contact" style="--card-color: var(--purple)">
        <div>
          <div class="path-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"></circle><path d="M3 20c0-3.3 2.7-5 6-5s6 1.7 6 5"></path><path d="M16 6a3 3 0 0 1 0 5.5"></path><path d="M18 20c0-2.6-1-4-2.6-4.6"></path></svg></div>
          <h3>Hire Great Leaders</h3>
          <p>Executive recruiting and confidential search for stronger leadership teams.</p>
        </div>
        <span class="path-go">Hiring Solutions <ArrowIcon size={15} /></span>
      </a>
      <a class="path-card reveal" data-d="2" href="#contact" style="--card-color: var(--blue)">
        <div>
          <div class="path-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"></circle><circle cx="12" cy="12" r="4.5"></circle><circle cx="12" cy="12" r="1.3" fill="currentColor" stroke="none"></circle></svg></div>
          <h3>Develop Leaders</h3>
          <p>Coaching that improves communication, decision-making, and confidence.</p>
        </div>
        <span class="path-go">Coaching Solutions <ArrowIcon size={15} /></span>
      </a>
      <a class="path-card reveal" data-d="3" href="#contact" style="--card-color: var(--orange)">
        <div>
          <div class="path-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"><path d="M4 21V9l8-5 8 5v12"></path><path d="M4 21h16"></path><path d="M9 21v-5h6v5"></path></svg></div>
          <h3>Strengthen My Organization</h3>
          <p>HR consulting, workforce planning, compliance, and organizational support.</p>
        </div>
        <span class="path-go">HR Solutions <ArrowIcon size={15} /></span>
      </a>
    </div>

    <div class="audience-row reveal" style="margin-top:28px"><span class="aud-label">For Executives &amp; Professionals</span><span class="aud-line"></span></div>
    <a class="path-card wide reveal" href="#contact" style="--card-color: var(--gold)">
      <div class="pc-main">
        <div class="path-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M13 19c8-3 8-14 8-14s-11 0-14 8"></path><path d="M4 20s.5-4 3-6"></path><circle cx="15" cy="9" r="1.6"></circle></svg></div>
        <div class="pc-text">
          <h3>Advance My Career</h3>
          <p>For executives pursuing a leadership role, preparing for interviews, or planning a confident next move — your career deserves a strategy.</p>
        </div>
      </div>
      <span class="path-go">Career Solutions <ArrowIcon size={15} /></span>
    </a>
  </div>
</section>
